# figmaclaw environment variables
# Copy to .env and fill in your values: cp .env.example .env

# Required — Figma personal access token
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_API_KEY=figd_...

# Optional — Figma team ID for auto-discovery (figmaclaw list)
# FIGMA_TEAM_ID=

# Optional — webhook passcode (for figmaclaw apply-webhook validation)
# FIGMA_WEBHOOK_SECRET=

# Optional — Claude Code OAuth token (for CI enrichment via figmaclaw claude-run)
# CLAUDE_CODE_OAUTH_TOKEN=
